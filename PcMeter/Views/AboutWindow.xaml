<Window x:Class="PcMeter.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PC Meter"
        ResizeMode="NoResize"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Image Source="/Assets/pcmeter.ico" Width="32" Height="32"
                   VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="PC Meter" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Copyright and link -->
        <TextBlock Grid.Row="1" Margin="0,0,0,8">
            <Hyperlink x:Name="WebsiteLink" Click="WebsiteLink_Click">
                https://github.com/swvincent/PcMeter
            </Hyperlink>
        </TextBlock>

        <!-- Description -->
        <TextBlock Grid.Row="2" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Sends CPU and memory utilization data to a PC Meter device over a serial port."/>

        <!-- License -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <TextBox x:Name="LicenseTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     Background="Transparent"
                     BorderThickness="1"
                     Padding="4"
                     FontFamily="Consolas"
                     FontSize="11"/>
        </ScrollViewer>

        <!-- OK button -->
        <Button Grid.Row="4" Content="OK" Width="80"
                HorizontalAlignment="Right"
                IsDefault="True" IsCancel="True"
                Click="OkButton_Click"/>
    </Grid>
</Window>
