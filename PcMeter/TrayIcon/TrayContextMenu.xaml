<ResourceDictionary x:Class="PcMeter.TrayIcon.TrayContextMenu"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tb="http://www.hardcodet.net/taskbar">

    <tb:TaskbarIcon x:Key="TrayIcon"
                    IconSource="/Assets/pcmeter.ico"
                    ToolTipText="PC Meter">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="CpuMenuItem"
                          Header="CPU: ?"
                          IsEnabled="False"/>
                <MenuItem x:Name="MemMenuItem"
                          Header="Memory: ?"
                          IsEnabled="False"/>
                <Separator/>
                <MenuItem x:Name="ConnectMenuItem"
                          Header="_Connect"
                          IsCheckable="True"
                          Click="ConnectMenuItem_Click"/>
                <Separator/>
                <MenuItem x:Name="SettingsMenuItem"
                          Header="_Settings"
                          Click="SettingsMenuItem_Click"/>
                <MenuItem Header="_About"
                          Click="AboutMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"
                          Click="ExitMenuItem_Click"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

</ResourceDictionary>
