<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows7.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\pcmeter.ico</ApplicationIcon>
    <AssemblyName>PcMeter</AssemblyName>
    <RootNamespace>PcMeter</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.4.*" />
    <PackageReference Include="System.IO.Ports" Version="10.0.*" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\pcmeter.ico" />
  </ItemGroup>

</Project>
